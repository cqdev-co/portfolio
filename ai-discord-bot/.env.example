# ============================================================================
# ai-discord-bot configuration
# ============================================================================
# Normally these live in the repo-root .env / .env.local; this file documents
# what the bot reads. Do not commit real values.

# --- Supabase (shared with other services) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# --- Discord bot (NEW - create a bot in Discord Developer Portal) ----------
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Optional; if set, slash commands register only on this guild (instant).
# If unset, commands register globally (can take up to ~1 hour to propagate).
DISCORD_BOT_GUILD_ID=
# Channel the scheduled morning brief is posted to.
DISCORD_BOT_CHANNEL_ID=

# --- Ollama (must be running locally on your Mac) --------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:35b

# --- AgentOS (A2A server) --------------------------------------------------
AGENT_OS_HOST=127.0.0.1
AGENT_OS_PORT=7777

# --- Scheduler -------------------------------------------------------------
# Morning brief cron. Default: 08:30 ET on weekdays.
BRIEF_CRON_HOUR=8
BRIEF_CRON_MINUTE=30
BRIEF_CRON_TZ=America/New_York

# --- Optional market data sources ------------------------------------------
FMP_API_KEY=
