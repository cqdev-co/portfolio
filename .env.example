# Vercel Configuration
VERCEL_TOKEN=a
VERCEL_ORG_ID=a
VERCEL_PROJECT_ID=a

# GitHub Token
PAT_FOR_APPROVAL=a

# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL=a
NEXT_PUBLIC_SUPABASE_ANON_KEY=a

# OpenAI API Configuration
OPENAI_API_KEY=a

# Alpha Vantage API Key
ALPHA_VANTAGE_API_KEY=a

# Financial Modeling Prep
# Used by Phase 1 Xylo tools: get_earnings_calendar (multi-ticker upcoming
# earnings) and get_recent_news (one of three deduped news sources).
# Without this key the earnings tool returns "unavailable" and news still
# works on Yahoo + Polygon.
FMP_API_KEY=your_fmp_key

# Image Generation Settings
DEFAULT_STYLE=neural-network
DEFAULT_QUALITY=hd
MAX_BATCH_SIZE=10

# Output Settings
OUTPUT_FORMAT=PNG
JPEG_QUALITY=95
CLEANUP_DAYS=30

# ============================================================================
# AI Configuration (see docs/local-ai-eval/README.md for details)
# ============================================================================
# Drives the @portfolio/ai-config resolver.
#   ENV=dev   -> local Ollama on localhost:11434 (qwen3.6:35b, gemma4:26b)
#   ENV=prod  -> Ollama cloud (requires OLLAMA_API_KEY)
#   unset     -> cloud (safe default for Vercel deploys; set OLLAMA_API_KEY)
ENV=dev

# Required when mode resolves to cloud. Get one at https://ollama.com/settings/keys.
# OLLAMA_API_KEY=

# Optional: force a specific mode regardless of ENV. Valid: local | cloud.
# AI_MODE=

# Optional overrides (rarely needed):
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_LOCAL_MODEL_OVERRIDE=
# OLLAMA_CLOUD_MODEL_OVERRIDE=

# ============================================================================
# ai-discord-bot (see docs/ai-discord-bot/README.md)
# ============================================================================
# Local-only Python Discord bot. Multi-agent (orchestrator + 4 specialists)
# talking over A2A, using local qwen3.6:35b. Run with `bun run py:bot`.

# Bot token from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=
# Guild (server) ID - right-click your server -> Copy ID. If set, slash
# commands register only on this guild (instant). If unset, commands register
# globally (can take up to ~1h to appear).
# DISCORD_BOT_GUILD_ID=
# Channel for the scheduled morning brief.
# DISCORD_BOT_CHANNEL_ID=

# Ollama model the bot uses (must be pulled locally).
# OLLAMA_MODEL=qwen3.6:35b

# AgentOS (A2A server) bind address. Localhost only; do not expose.
# AGENT_OS_HOST=127.0.0.1
# AGENT_OS_PORT=7777

# Morning brief cron. Defaults: 08:30 America/New_York on weekdays.
# BRIEF_CRON_HOUR=8
# BRIEF_CRON_MINUTE=30
# BRIEF_CRON_TZ=America/New_York

